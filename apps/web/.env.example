# Browser (Vite) — prefix VITE_
VITE_RPC_URL=https://api.devnet.solana.com
# VITE_PROGRAM_ID=...  # defaults to idl/creator_treasury.json address
# Optional: call serverless API on another origin
# VITE_API_BASE_URL=https://your-deployment.vercel.app

# Optional — cloud email + synced encrypted keybags (see ../../docs/SUPABASE-AUTH.md)
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_public_key

# Set on Vercel (serverless) — no VITE_ prefix
# SOLANA_RPC_URL=https://api.devnet.solana.com
# TREASURY_API_SECRET=generate-a-long-random-string
# JWT_EMBED_SECRET=another-long-random-string
# WEBHOOK_SIGNING_SECRET=another-secret-for-hmac
# WEBHOOK_DELIVERY_URL=https://discord.com/api/webhooks/...
#
# Generate a paste-ready file for Vercel → Import .env:
#   npm run vercel:generate-env
#   (outputs apps/web/.env.vercel.paste — gitignored)
# Template without secrets: apps/web/vercel.environment.template
#
# Product overview + operations: ../../docs/ESSENTIALS.md
#
# Cron crank (optional): see vercel.json crons + api/cron/treasury-crank.ts
# CRON_SECRET=
# CRANK_TEAM_LEAD=
# CRANK_PROJECT_ID=
# CRANK_FEE_PAYER_JSON=
