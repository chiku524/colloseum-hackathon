# Paste into the `.env` used by the official Supabase Docker stack (self-hosting).
# Use with:
#   - supabase/docker-compose.self-host-mailpit.yml (merge into upstream compose), or
#   - any Mailpit container named service "mailpit" on the same Docker network as `auth`.
#
# Upstream defaults often use SMTP_HOST=supabase-mail — override to mailpit when using our overlay.
# https://supabase.com/docs/guides/self-hosting/docker#configuring-an-email-server

# Published ports for docker-compose.self-host-mailpit.yml (optional; defaults match)
MAILPIT_HTTP_PORT=8025
MAILPIT_SMTP_PORT=1025

SMTP_ADMIN_EMAIL=noreply@web3stronghold.local
SMTP_HOST=mailpit
SMTP_PORT=1025
# Mailpit accepts unauthenticated SMTP on a trusted network; leave empty.
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=web3stronghold
