# Copy to .env.supabase.local (gitignored) for setup scripts.
# Used by: npm run setup:apply-keybags (overrides other env for these keys only)

# Direct Postgres URL (port 5432) from Supabase → Settings → Database → URI
# SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Management API — personal token from https://supabase.com/dashboard/account/tokens
# (NOT the anon key / NOT service_role — those are eyJ... JWTs and will return 401)
# SUPABASE_ACCESS_TOKEN=

# Optional overrides for npm run setup:supabase-auth-urls
# SUPABASE_SITE_URL=http://localhost:5173
# SUPABASE_URI_ALLOW_LIST=https://your-app.vercel.app
