# =============================================================================
# Copy to .env.supabase.local (gitignored) at the REPO ROOT.
# Loaded by setup scripts after apps/web env — values here OVERRIDE the same keys.
# =============================================================================

# -----------------------------------------------------------------------------
# Required on IPv4-only Windows for keybags migration (unless you paste Session URI below)
# -----------------------------------------------------------------------------
# Personal access token (Account → Access tokens). NOT anon / service_role (those are eyJ…).
SUPABASE_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Strongly recommended if pooler password errors persist
# -----------------------------------------------------------------------------
# Paste the full "Session mode" URI from Supabase → Connect → Session (URI tab).
# User must be postgres.YOUR_PROJECT_REF — not plain postgres. Include ?sslmode=require
# SUPABASE_DB_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# Alternative: direct connection (IPv6 only — often fails on Windows without IPv6)
# SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# -----------------------------------------------------------------------------
# Optional — npm run setup:apply-keybags also accepts (first match wins if no STRONGHOLD_* set):
# -----------------------------------------------------------------------------
# From Vercel env pull into apps/web — you can duplicate here to override for CLI-only runs:
# DATABASE_URL=
# POSTGRES_URL_NON_POOLING=
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=

# -----------------------------------------------------------------------------
# Optional — npm run setup:supabase-auth-urls / setup:check
# -----------------------------------------------------------------------------
# SUPABASE_PROJECT_REF=your_ref   # if not inferrable from VITE_PUBLIC_SUPABASE_URL
# SUPABASE_SITE_URL=http://localhost:5173
# SUPABASE_URI_ALLOW_LIST=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# Optional — duplicate here so setup:check sees them without apps/web pull
# -----------------------------------------------------------------------------
# VITE_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# (aliases: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY)
